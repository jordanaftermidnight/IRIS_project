{
  "name": "iris-ai",
  "version": "1.0.0",
  "description": "Iris — Integrated Runtime Intelligence Service. Cross-platform (Mac/Linux/Windows) 16-provider AI router with persistent sessions, MCP server (13 tools), live SSE event stream, council fan-out + LLM judge + merge, per-provider circuit breakers, native tool/function calling, Anthropic prompt caching, batch APIs (OpenAI + Anthropic), structured JSON logs, mTLS, mDNS discovery, optional MCP memory backend integration (e.g. localmem) for cross-session learning, audit log, per-tool /metrics, and a generic OpenAI-compatible adapter.",
  "main": "src/enhanced-ai.js",
  "type": "module",
  "bin": {
    "iris": "./src/enhanced-ai.js"
  },
  "preferGlobal": true,
  "scripts": {
    "start": "node src/enhanced-ai.js",
    "test": "node tests/test-runner.js",
    "test:examples": "node examples/basic-usage.js",
    "dev": "node --watch src/enhanced-ai.js",
    "health": "node src/enhanced-ai.js health",
    "models": "node src/enhanced-ai.js models",
    "providers": "node src/enhanced-ai.js providers",
    "lint": "eslint src/ tests/ examples/",
    "lint:fix": "eslint src/ tests/ examples/ --fix",
    "validate": "npm run lint && npm test",
    "prepack": "npm run validate"
  },
  "keywords": [
    "ai",
    "llm",
    "ollama",
    "gemini",
    "claude",
    "anthropic",
    "cli",
    "multi-provider",
    "automation",
    "machine-learning",
    "nlp",
    "chat"
  ],
  "author": "Jordan After Midnight",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jordanaftermidnight/IRIS_project.git"
  },
  "bugs": {
    "url": "https://github.com/jordanaftermidnight/IRIS_project/issues"
  },
  "homepage": "https://github.com/jordanaftermidnight/IRIS_project#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.9.0",
    "bonjour-service": "^1.4.2",
    "groq-sdk": "^0.26.0",
    "ollama": "^0.5.16",
    "openai": "^5.8.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "eslint": "^10.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/jordanaftermidnight"
  }
}
