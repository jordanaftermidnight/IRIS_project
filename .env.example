# IRIS environment configuration
#
# Copy this file to .env and fill in the values you have. IRIS picks up
# whatever's set; missing keys just mean that provider sits in
# "needs API key" status (see `iris providers`).
#
# Keep secrets in ~/.secrets sourced from your shell rc, OR load this
# .env via dotenv. Either way, never commit the populated file.

# ---- Native providers (priority 1–5) ----

# Ollama (local, free). Default host works for most setups.
OLLAMA_HOST=http://localhost:11434

# OpenAI — GPT-5.4 / 5.5 / o4-mini lineup
OPENAI_API_KEY=

# Anthropic Claude — Opus 4.8 / Sonnet 4.6 / Haiku 4.5
ANTHROPIC_API_KEY=

# Google Gemini — 3.1 Pro / 3.5 Flash / 3.1 Flash-Image
GEMINI_API_KEY=

# Groq — Llama 4 Scout, GPT OSS 20B/120B
GROQ_API_KEY=

# ---- Built-in OpenAI-compatible registry ----

MOONSHOT_API_KEY=          # Kimi
MINIMAX_API_KEY=           # MiniMax
DEEPSEEK_API_KEY=          # DeepSeek
XAI_API_KEY=               # xAI Grok
MISTRAL_API_KEY=           # Mistral La Plateforme
CEREBRAS_API_KEY=          # Cerebras
TOGETHER_API_KEY=          # Together AI
OPENROUTER_API_KEY=        # OpenRouter (300+ models)
PERPLEXITY_API_KEY=        # Perplexity (search-augmented)

# Optional v1.0 additions
COHERE_API_KEY=            # Cohere Command R+
HF_API_KEY=                # HuggingFace Inference API

# ---- IRIS runtime ----

# SQLite store path. Default: ~/.iris/iris.db
IRIS_DB=

# Default session id for `iris chat ...` so you don't need --session= every call.
IRIS_SESSION=

# Bearer token required by `iris serve` when set.
# Generate with: openssl rand -hex 32
IRIS_AUTH_TOKEN=

# JSONL audit log path. Default: ~/.iris/audit.jsonl. Set to "" to disable.
IRIS_AUDIT_LOG=

# Log level: trace | debug | info | warn | error | fatal | silent
# Default: info
IRIS_LOG_LEVEL=

# Log format: pretty | json
# Default: pretty on TTY, json on pipes and `iris serve`.
IRIS_LOG_FORMAT=
